{
  "name": "@ont/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ont": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
