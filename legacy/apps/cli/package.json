  },
  "dependencies": {
    "@ont/architect": "file:../../packages/architect",
    "@ont/bitcoin": "file:../../packages/bitcoin",
    "@ont/core": "file:../../packages/core",
    "@ont/protocol": "file:../../packages/protocol",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "ecpair": "^3.0.1",
    "tiny-secp256k1": "^2.2.4"
  }
}
