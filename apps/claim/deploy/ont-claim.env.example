# Installed at /etc/ont/ont-claim.env on the droplet.
CLAIM_WEB_PORT=3003
CLAIM_PUBLISHER_URL=http://127.0.0.1:7878
CLAIM_NETWORK_LABEL=signet
CLAIM_RATE_LIMIT_PER_MINUTE=10
# Optional: resolver base URL for the gap-scan to union (authoritative, cross-publisher).
# Unset → the gap-scan uses the publisher only.
# CLAIM_RESOLVER_URL=http://127.0.0.1:8787
