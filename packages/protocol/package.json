{
  "name": "@ont/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auction-bid-package": {
      "types": "./dist/auction-bid-package.d.ts",
      "default": "./dist/auction-bid-package.js"
    },
    "./bond": {
      "types": "./dist/bond.d.ts",
      "default": "./dist/bond.js"
    },
    "./bytes": {
      "types": "./dist/bytes.d.ts",
      "default": "./dist/bytes.js"
    },
    "./names": {
      "types": "./dist/names.d.ts",
      "default": "./dist/names.js"
    },
    "./value-record": {
      "types": "./dist/value-record.d.ts",
      "default": "./dist/value-record.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "bip322-js": "^3.0.0",
    "tiny-secp256k1": "^2.2.4"
  }
