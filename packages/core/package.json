{
  "name": "@ont/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/src/index.d.ts",
      "default": "./dist/core/src/index.js"
    },
    "./auction-policy": {
      "types": "./dist/core/src/auction-policy.d.ts",
      "default": "./dist/core/src/auction-policy.js"
    },
    "./experimental-auction": {
      "types": "./dist/core/src/experimental-auction.d.ts",
      "default": "./dist/core/src/experimental-auction.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build -w @ont/protocol && npm run build -w @ont/bitcoin && npm run build -w @ont/consensus && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ont/bitcoin": "file:../bitcoin",
    "@ont/consensus": "file:../consensus",
    "@ont/protocol": "file:../protocol",
    "bitcoinjs-lib": "^7.0.1"
  },
  "devDependencies": {
    "ecpair": "^3.0.1",
    "tiny-secp256k1": "^2.2.4",
    "vitest": "^3.2.4"
  }
}
