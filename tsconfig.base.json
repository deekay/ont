{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@ont/architect": ["packages/architect/src/index.ts"],
      "@ont/architect/browser": ["packages/architect/src/browser.ts"],
      "@ont/adapter-da": ["packages/adapter-da/src/index.ts"],
      "@ont/adapter-header": ["packages/adapter-header/src/index.ts"],
      "@ont/adapter-indexer": ["packages/adapter-indexer/src/index.ts"],
      "@ont/adapter-publisher": ["packages/adapter-publisher/src/index.ts"],
      "@ont/adapter-resolver": ["packages/adapter-resolver/src/index.ts"],
      "@ont/anchor-store": ["packages/anchor-store/src/index.ts"],
      "@ont/bitcoin": ["packages/bitcoin/src/index.ts"],
      "@ont/claim-path": ["packages/claim-path/src/index.ts"],
      "@ont/consensus": ["packages/consensus/src/index.ts"],
      "@ont/core": ["packages/core/src/index.ts"],
      "@ont/core/auction-policy": ["packages/core/src/auction-policy.ts"],
      "@ont/core/experimental-auction": ["packages/core/src/experimental-auction.ts"],
      "@ont/db": ["packages/db/src/index.ts"],
      "@ont/evidence": ["packages/evidence/src/index.ts"],
      "@ont/protocol": ["packages/protocol/src/index.ts"],
      "@ont/protocol/auction-bid-package": ["packages/protocol/src/auction-bid-package.ts"],
      "@ont/protocol/bond": ["packages/protocol/src/bond.ts"],
      "@ont/protocol/bytes": ["packages/protocol/src/bytes.ts"],
      "@ont/protocol/names": ["packages/protocol/src/names.ts"],
      "@ont/protocol/value-record": ["packages/protocol/src/value-record.ts"],
      "@ont/protocol/wire": ["packages/protocol/src/wire.ts"]
    }
  }
}
