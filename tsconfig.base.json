{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@ont/architect": ["packages/architect/src/index.ts"],
      "@ont/architect/browser": ["packages/architect/src/browser.ts"],
      "@ont/bitcoin": ["packages/bitcoin/src/index.ts"],
      "@ont/core": ["packages/core/src/index.ts"],
      "@ont/core/auction-policy": ["packages/core/src/auction-policy.ts"],
      "@ont/core/experimental-auction": ["packages/core/src/experimental-auction.ts"],
      "@ont/db": ["packages/db/src/index.ts"],
      "@ont/protocol": ["packages/protocol/src/index.ts"]
    }
  }
}
