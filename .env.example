# ONT clean-build go-live stack — docker compose operator config.
# Copy to .env and fill in the secrets. See docs/operate/G3_CLEAN_SLATE_VPS.md.
#
# Fixed runtime wiring (ONT_SOURCE, ONT_CHAIN, ONT_RPC_URL, ONT_STORE, ONT_STORE_DIR, PORT, ONT_RESOLVER_URL)
# lives in docker-compose.yml, not here — this file is only the operator-chosen secrets, binds, and knobs.

# --- Bitcoin Core (signet) RPC auth ---------------------------------------------------------------
# The indexer (ingest) and publisher (broadcast) reach bitcoind at http://bitcoind:38332 with these
# credentials. Required (no default password).
ONT_RPC_USER=ontrpc
ONT_RPC_PASSWORD=replace-me-with-a-strong-secret

# Operator-pinned Bitcoin Core image for the bitcoind service. Use a signet-capable Core >= 25 build you trust.
BITCOIND_IMAGE=btcpayserver/bitcoin:28.1

# --- Host bindings ----------------------------------------------------------------------------------
# Published ports bind to localhost by default; put a reverse proxy / firewall in front before exposing.
# The publisher exposes /broadcast (relays signed raws to the node) — keep it on localhost unless fronted.
ONT_RESOLVER_BIND=127.0.0.1
ONT_WEB_BIND=127.0.0.1
ONT_PUBLISHER_BIND=127.0.0.1

# --- Indexer poll cadence ---------------------------------------------------------------------------
# How often the indexer polls bitcoind for new confirmed anchors, in milliseconds.
INDEXER_POLL_MS=10000

# --- A' fixture enforcement (optional; default compose path is off) ---------------------------------
# Set ONT_ENFORCEMENT=fixture-file only when /app/.data/batch-material.json has already been generated and
# placed in the shared ont_data volume before the matching RootAnchor is mined/ingested.
ONT_ENFORCEMENT=off
ONT_BATCH_MATERIAL_FILE=/app/.data/batch-material.json

# --- Optional verifier header provider --------------------------------------------------------------
# Client-side verify defaults to the resolver-served header range. Set this on verifier surfaces that
# should fetch the same fixed signet range from Esplora for liveness. This does not upgrade signet
# header authenticity: signet remains provider-trusted until the BIP325 challenge verifier ships.
# ONT_HEADER_PROVIDER=esplora
# ONT_ESPLORA_URL=https://mempool.space/signet/api
