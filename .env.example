# ONT clean-build go-live stack — docker compose operator config.
# Copy to .env and fill in the secrets. See docs/operate/G3_CLEAN_SLATE_VPS.md.
#
# Fixed runtime wiring (ONT_SOURCE, ONT_CHAIN, ONT_RPC_URL, ONT_STORE, ONT_STORE_DIR, PORT, ONT_RESOLVER_URL)
# lives in docker-compose.yml, not here — this file is only the operator-chosen secrets, binds, and knobs.

# --- Bitcoin Core (private signet) RPC auth -------------------------------------------------------
# The indexer (ingest) and publisher (broadcast) reach bitcoind at http://bitcoind:38332 with these
# credentials. Required (no default password).
ONT_RPC_USER=ontrpc
ONT_RPC_PASSWORD=replace-me-with-a-strong-secret

# Operator-pinned Bitcoin Core image for the bitcoind service. Use a signet-capable Core >= 25 build you trust.
BITCOIND_IMAGE=btcpayserver/bitcoin:28.1

# Private-signet challenge. Default 51 = OP_TRUE, so the miner needs no signing key.
ONT_SIGNET_CHALLENGE=51

# --- Private-signet miner --------------------------------------------------------------------------
# Required: a signet legacy funding address controlled by the off-box wallet that will sign the anchor tx.
# The miner sends bootstrap + ongoing coinbase rewards here; after 110 blocks mature coinbase exists.
ONT_SIGNET_MINER_ADDRESS=replace-with-off-box-legacy-signet-address
# Helper wallet loaded only so Bitcoin Core's signet miner can resolve the reward scriptPubKey.
ONT_SIGNET_MINER_WALLET=ont_miner
ONT_SIGNET_BOOTSTRAP_BLOCKS=110
ONT_SIGNET_MINE_INTERVAL_SECONDS=45
ONT_SIGNET_MINE_NBITS=1e0377ae

# Bitcoin Core source tag used only to copy contrib/signet/miner into the miner sidecar.
ONT_SIGNET_MINER_BITCOIN_VERSION=28.1

# --- Client launch checkpoint (private signet genesis) -----------------------------------------------
# The bundled default remains the public-signet checkpoint for hermetic tests. The deployed private-signet
# stack overrides it so CLI/web/mobile validate headers forward from THIS private chain's genesis.
ONT_LAUNCH_CHECKPOINT_HEIGHT=0
ONT_LAUNCH_CHECKPOINT_HASH=00000008819873e925422c1ff0f99f7cc9bbb232af63a077a480a3633bee1ef6
ONT_LAUNCH_CHECKPOINT_BITS=0x1e0377ae
ONT_LAUNCH_CHECKPOINT_TIME=1598918400
ONT_LAUNCH_CHECKPOINT_EPOCH_START=1598918400
ONT_LAUNCH_CHECKPOINT_WORK=49d414

# --- Host bindings ----------------------------------------------------------------------------------
# Published ports bind to localhost by default; put a reverse proxy / firewall in front before exposing.
# The publisher exposes /broadcast (relays signed raws to the node) — keep it on localhost unless fronted.
ONT_RESOLVER_BIND=127.0.0.1
ONT_WEB_BIND=127.0.0.1
ONT_PUBLISHER_BIND=127.0.0.1

# --- Indexer poll cadence ---------------------------------------------------------------------------
# How often the indexer polls bitcoind for new confirmed anchors, in milliseconds.
INDEXER_POLL_MS=10000

# --- A' fixture enforcement (optional; default compose path is off) ---------------------------------
# Set ONT_ENFORCEMENT=fixture-file only when /app/.data/batch-material.json has already been generated and
# placed in the shared ont_data volume before the matching RootAnchor is mined/ingested.
ONT_ENFORCEMENT=off
ONT_BATCH_MATERIAL_FILE=/app/.data/batch-material.json

# --- Verifier header provider -----------------------------------------------------------------------
# Client-side verify defaults to the resolver-served header range. Set to esplora only for liveness checks
# against an Esplora-compatible source. This does not upgrade signet header authenticity: signet remains
# provider-trusted until the BIP325 challenge verifier ships.
ONT_HEADER_PROVIDER=resolver
# ONT_ESPLORA_URL=https://mempool.space/signet/api
